{
  "commands": {
    "build": "make build",
    "coverage": "make test-coverage",
    "lint": "make lint",
    "tests": "make test",
    "types": "make type-check"
  },
  "description": "Quality gate configuration for mixed project",
  "thresholds": {
    "build": {
      "operator": "=",
      "type": "exit_code",
      "value": 0
    },
    "coverage": {
      "operator": "≥",
      "type": "percentage"
    },
    "lint": {
      "operator": "=",
      "type": "count",
      "value": 0
    },
    "tests": {
      "operator": "≥",
      "type": "count"
    },
    "types": {
      "operator": "≤",
      "type": "count"
    }
  }
}
