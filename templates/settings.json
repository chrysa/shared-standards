{
  "_comment": "Claude Code settings template — copy to .claude/settings.json and customize",
  "autoCompact": true,
  "autoCompactThreshold": 0.85,
  "hooks": {
    "Notification": [
      {
        "command": "notify-send 'Claude Code' '$CLAUDE_NOTIFICATION'",
        "name": "notify-user-input"
      }
    ],
    "PostToolUse": [
      {
        "command": "node .claude/hooks/verifiable-thresholds.cjs",
        "matcher": "Write|Edit|MultiEdit",
        "name": "verifiable-thresholds",
        "timeout": 10000
      }
    ],
    "PreCompact": [
      {
        "command": "~/.claude/hooks/pre-compact.sh",
        "name": "pre-compact",
        "timeout": 10000
      }
    ],
    "PreToolUse": [
      {
        "command": "node .claude/hooks/secret-scanner.cjs",
        "matcher": "Bash",
        "name": "secret-scanner",
        "timeout": 10000
      },
      {
        "command": "node .claude/hooks/circuit-breaker.cjs",
        "matcher": "Bash",
        "name": "circuit-breaker",
        "timeout": 5000
      }
    ],
    "UserPromptSubmit": [
      {
        "command": "node .claude/hooks/frustration-detection.cjs",
        "matcher": "*",
        "name": "frustration-detection",
        "timeout": 5000
      }
    ]
  }
}
